{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
      "paths": {
      "@opensource/core": ["./src/index.ts"],
      "@opensource/timeline": ["../timeline/src/common/index.ts"],
      "@opensource/video-preview": ["../video-preview/src/index.ts"]
    }
  },
  "include": ["src", "demo"]
}
